# Corbel web — PUBLIC build-time config only. Anything here ships to the browser bundle.
# NEVER put secrets (API keys, connection strings, signing keys) in a VITE_ variable.
# Copy to `.env.local` (git-ignored) to override locally.

# Display name shown in the navbar / document title.
VITE_APP_NAME=Corbel

# API base URL. Leave EMPTY for the default same-origin setup: the OpenAPI paths already include the
# "/api" prefix, and in dev Vite proxies "/api" while in prod nginx proxies it — so an empty base is
# correct. Only set this (e.g. https://api.example.com) when fronting the API on a different host.
# (A value of "/api" would double-prefix every call to /api/api/... and 404 the whole app.)
VITE_API_BASE_URL=

# Dev-only: where Vite forwards "/api" during `pnpm dev`. Match your Kestrel HTTPS port
# (see src/Corbel.Api/Properties/launchSettings.json). Not bundled — read only by vite.config.ts.
VITE_DEV_PROXY_TARGET=https://localhost:7080
