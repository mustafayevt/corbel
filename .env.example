# Corbel environment configuration.
# Copy this file to `.env` (which is gitignored) and replace every CHANGE_ME value.
#
# NEVER commit real secrets. For local dev the API reads its JWT key from `dotnet user-secrets`
# (see `just bootstrap`); in CI/production these belong in your secret manager, not in a file.
# This `.env` is consumed by docker-compose (`just up`) for the container stack.

# ---- PostgreSQL ----
POSTGRES_USER=corbel
POSTGRES_PASSWORD=CHANGE_ME_postgres_password
POSTGRES_DB=corbel

# ---- API: database connection ----
# Host is the compose service name ("postgres"). Use "localhost" when running the API outside compose.
# Keep the credentials in sync with POSTGRES_USER / POSTGRES_PASSWORD above.
ConnectionStrings__corbel=Host=postgres;Port=5432;Database=corbel;Username=corbel;Password=CHANGE_ME_postgres_password

# ---- API: schema migrations ----
# Apply EF migrations on startup (default: true) — convenient for single-instance local/compose runs.
# Set to false when running MULTIPLE API replicas: concurrent startups would race to migrate the same
# database. Instead migrate once out-of-process before rollout (the EF bundle / `just migrate`).
Database__MigrateOnStartup=true

# ---- API: JWT (HS256 — SigningKey MUST be at least 32 characters / 256-bit) ----
Jwt__Issuer=corbel
Jwt__Audience=corbel
Jwt__SigningKey=CHANGE_ME_min_32_chars________________

# ---- API: auth cookies ----
# The refresh + CSRF cookies are emitted with the Secure attribute by default, so they require HTTPS.
# Browsers make an exception for http://localhost, so `just up` works over plain HTTP locally. For ANY
# non-localhost host you MUST serve the stack behind TLS, or the browser silently drops these cookies and
# cookie-mode refresh/logout/CSRF break (login still appears to work — the access token is in the body).
# Only for plain-HTTP testing on a non-localhost host, flip this to false (never in production):
# CookieAuth__Secure=false
# SameSite policy for the auth cookies: Lax (default) for a same-site SPA, None (with Secure) for cross-site.
# CookieAuth__SameSite=Lax

# ---- API: initial admin seed (created on first run when the user table is empty) ----
Seed__AdminEmail=admin@corbel.local
Seed__AdminPassword=CHANGE_ME_Admin_Pass1!
