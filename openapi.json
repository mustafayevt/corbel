            "type": "string"
          },
          "content": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "HttpValidationProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": [
              "null",
              "string"
            ]
          },
          "title": {
            "type": [
              "null",
              "string"
            ]
          },
          "status": {
            "type": [
              "null",
              "integer"
            ],
            "format": "int32"
          },
          "detail": {
            "type": [
              "null",
              "string"
            ]
          },
          "instance": {
            "type": [
              "null",
              "string"
            ]
          },
          "errors": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "errorCode": {
            "type": "string"
          },
          "traceId": {
            "type": "string"
          }
        }
      },
      "LoginRequest": {
        "required": [
          "email",
          "password"
        ],
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "useCookies": {
            "type": "boolean",
            "default": true
          }
        },
        "description": "UseCookies selects the transport: true (browser default) sets the httpOnly refresh cookie + CSRF; false returns the refresh token in the body (mobile/bearer)."
      },
      "LogoutRequest": {
        "required": [
          "refreshToken"
        ],
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": [
              "null",
              "string"
            ]
          }
        },
        "description": "Bearer-mode body; in cookie mode the refresh token is read from the httpOnly cookie."
      },
      "MessageResponse": {
        "required": [
          "message"
        ],
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        },
        "description": "A generic, non-revealing acknowledgement returned by flows that must not leak account existence."
      },
      "NoteResponse": {
        "required": [
          "id",
          "title",
          "content",
          "isArchived",
          "createdAtUtc"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "isArchived": {
            "type": "boolean"
          },
          "createdAtUtc": {
            "type": "string",
            "format": "date-time"
          }
        },
        "description": "The wire contract for a note. The entity is never serialized directly — slices project to this record (via\nExpression&lt;Func&lt;Note, NoteResponse&gt;&gt; NoteResponse.Projection in SQL, or NoteResponse NoteResponse.From(Note note) for an already-loaded entity), so the API surface stays\ndecoupled from the persistence model."
      },
      "PagedResultOfNoteResponse": {
        "required": [
          "items",
          "page",
          "pageSize",
          "totalCount",
          "totalPages",
          "hasNext",
          "hasPrevious"
        ],
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/NoteResponse"
            }
          },
          "page": {
            "type": "integer",
            "format": "int32"
          },
          "pageSize": {
            "type": "integer",
            "format": "int32"
          },
          "totalCount": {
            "type": "integer",
            "format": "int32"
          },
          "totalPages": {
            "type": "integer",
            "format": "int32"
          },
          "hasNext": {
            "type": "boolean"
          },
          "hasPrevious": {
            "type": "boolean"
          }
        },
        "description": "Consistent list envelope returned by every paginated endpoint → generates a clean PagedResult&lt;T&gt; in the TS client."
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": [
              "null",
              "string"
            ]
          },
          "title": {
            "type": [
              "null",
              "string"
            ]
          },
          "status": {
            "type": [
              "null",
              "integer"
            ],
            "format": "int32"
          },
          "detail": {
            "type": [
              "null",
              "string"
            ]
          },
          "instance": {
            "type": [
              "null",
              "string"
            ]
          },
          "errorCode": {
            "type": "string"
          },
          "traceId": {
            "type": "string"
          }
        }
      },
      "RefreshRequest": {
        "required": [
          "refreshToken"
        ],
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": [
              "null",
              "string"
            ]
          }
        },
        "description": "Bearer-mode request body. In cookie mode the token is read from the httpOnly cookie instead."
      },
      "RegisterRequest": {
        "required": [
          "email",
          "password",
          "displayName"
        ],
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "displayName": {
            "type": [
              "null",
              "string"
            ]
          }
