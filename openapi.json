  "tags": [
    {
      "name": "Notes",
      "description": "CRUD for the authenticated user's notes — the reference vertical slice. Every note is owned by its creator; a note you don't own is indistinguishable from one that doesn't exist (404)."
    },
    {
      "name": "Auth",
      "description": "Registration, sign-in, token refresh, sign-out, the current-user profile, and password changes. Supports both the cookie (browser) and bearer (native) transports."
    },
    {
      "name": "Admin",
      "description": "Endpoints gated by the Admin role."
    }
  ]
