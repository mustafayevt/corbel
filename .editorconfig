root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{json,yml,yaml,js,jsx,ts,tsx,css,html,md}]
indent_size = 2

[*.{csproj,props,targets,slnx,xml}]
indent_size = 2

[*.cs]
# Namespaces & usings
csharp_style_namespace_declarations = file_scoped:warning
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false
csharp_using_directive_placement = outside_namespace:warning

# var preferences — be explicit only where the type isn't obvious
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = true:silent

# Modern C# style
csharp_style_expression_bodied_methods = when_on_single_line:silent
csharp_style_prefer_primary_constructors = true:suggestion
csharp_prefer_braces = when_multiline:silent
dotnet_style_prefer_collection_expression = true:suggestion
csharp_style_prefer_pattern_matching = true:suggestion
dotnet_style_require_accessibility_modifiers = always:warning

# Naming: const & static readonly fields are PascalCase.
# These must precede the private-field rule below — naming rules are first-match-wins, and without
# them the _camelCase rule wrongly flags PascalCase consts/static-readonly (which fails `dotnet format`).
dotnet_naming_rule.constant_fields_pascal.severity = warning
dotnet_naming_rule.constant_fields_pascal.symbols = constant_fields
dotnet_naming_rule.constant_fields_pascal.style = pascal_case
dotnet_naming_symbols.constant_fields.applicable_kinds = field
dotnet_naming_symbols.constant_fields.required_modifiers = const

dotnet_naming_rule.static_readonly_pascal.severity = warning
dotnet_naming_rule.static_readonly_pascal.symbols = static_readonly_fields
dotnet_naming_rule.static_readonly_pascal.style = pascal_case
dotnet_naming_symbols.static_readonly_fields.applicable_kinds = field
dotnet_naming_symbols.static_readonly_fields.required_modifiers = static,readonly

dotnet_naming_style.pascal_case.capitalization = pascal_case

# Naming: private instance fields _camelCase
dotnet_naming_rule.private_fields_underscore.severity = warning
dotnet_naming_rule.private_fields_underscore.symbols = private_fields
dotnet_naming_rule.private_fields_underscore.style = underscore_prefix
dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_style.underscore_prefix.capitalization = camel_case
dotnet_naming_style.underscore_prefix.required_prefix = _

# Quiet the opinionated analyzer rules that fight a pragmatic starter
dotnet_diagnostic.CA1515.severity = none   # may make public types internal
dotnet_diagnostic.MA0048.severity = none   # file name must match type name
dotnet_diagnostic.MA0051.severity = suggestion
dotnet_diagnostic.MA0004.severity = none   # ConfigureAwait(false) — unnecessary in ASP.NET Core apps (no sync context)
dotnet_diagnostic.RCS1194.severity = none  # implement standard exception ctors — noise for purpose-built domain exceptions
dotnet_diagnostic.MA0026.severity = none   # TODO comments are acceptable in a starter template
dotnet_diagnostic.CA1716.severity = none   # identifier vs. language-keyword conflict — irrelevant (no VB consumers)
dotnet_diagnostic.CA1711.severity = none   # type-name-suffix pedantry
dotnet_diagnostic.CA1848.severity = suggestion  # LoggerMessage source-gen — used on hot paths; a hint elsewhere
dotnet_diagnostic.CA1873.severity = suggestion  # guard expensive logging — covered by LoggerMessage on hot paths

[tests/**.cs]
# Test projects: relax the strict rules
dotnet_diagnostic.CA1707.severity = none   # underscores in test method names
dotnet_diagnostic.MA0004.severity = none

[src/**.cs]
# Self-police the single Corbel.<Layer> namespace scheme: a file's namespace must match its folder.
dotnet_style_namespace_match_folder = true
dotnet_diagnostic.IDE0130.severity = warning

[src/Corbel.ServiceDefaults/**.cs]
# Aspire convention: ServiceDefaults' Extensions intentionally lives in Microsoft.Extensions.Hosting.
dotnet_diagnostic.IDE0130.severity = none

[**/Migrations/*.cs]
# EF-scaffolded migrations are generated code — exempt from style/quality analyzers.
generated_code = true
dotnet_diagnostic.CA1861.severity = none
dotnet_diagnostic.IDE0161.severity = none
dotnet_diagnostic.IDE0130.severity = none
